apiVersion: monitoring.grafana.com/v1alpha1
kind: Alloy
metadata:
  name: alloy-logs
  namespace: alloy-system
spec:
  env:
    - name: LOKI_ENDPOINT
      value: "LOKI_ENDPOINT_PLACEHOLDER"
    - name: MIMIR_ENDPOINT
      value: "MIMIR_ENDPOINT_PLACEHOLDER"
    - name: ENVIRONMENT
      value: "stage"
